UPDATE movies SET earnings = 60000000 WHERE title = "Selma";

-- (xviii). Rank movies by earnings
SELECT title, earnings,
       RANK() OVER (ORDER BY earnings DESC) AS ranking
FROM movies;

-- (xix). Filter earnings (above / below)
SELECT title, earnings
FROM movies
WHERE earnings > 100000000;

SELECT title, earnings
FROM movies
WHERE earnings < 50000000;

--- (xx). Logical operators (AND, OR, NOT)
SELECT title, earnings
FROM movies
WHERE (earnings > 50000000 AND earnings < 200000000)
   OR NOT (title = "Selma");
